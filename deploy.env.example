# UrsaHQ Launcher — Deploy Configuration
# Copy this to .env and fill in your values:
#   cp deploy.env.example .env
# Then run:
#   ./docker/deploy-launcher.sh

# Path to Flutter SDK installation
FLUTTER_HOME=/path/to/flutter

# Path to the ursahq-infra repo (for nginx-proxy-manager config)
INFRA_DIR=/path/to/ursahq-infra

# Your public domain
DOMAIN=your-domain.example.com

# nginx-proxy-manager proxy host ID number (check /data/nginx/proxy_host/)
NGINX_PROXY_HOST_ID=5

# IP or hostname of your secondary machine running *arr services
NUC_HOST=nuc-hostname-or-ip
